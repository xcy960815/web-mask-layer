{
  "name": "web-mask-layer",
  "version": "0.2.0",
  "description": "一个简单、轻量级且可自定义的 Web 遮罩层",
  "main": "dist/web-mask-layer.umd.js",
  "module": "dist/web-mask-layer.es.js",
  "style": "dist/web-mask-layer.css",
  "typings": "./types/web-mask-layer.d.ts",
  "files": [
    "dist",
    "types",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./types/web-mask-layer.d.ts",
      "import": "./dist/web-mask-layer.es.js",
      "default": "./dist/web-mask-layer.umd.js"
    },
    "./style.css": "./dist/web-mask-layer.css",
    "./dist/web-mask-layer.css": "./dist/web-mask-layer.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "check": "vue-tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "link": "npm link && npm link web-mask-layer",
    "prepare": "husky",
    "preview": "vite preview",
    "serve": "vite"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,less,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcy960815/web-mask-layer.git"
  },
  "author": {
    "name": "xcy960815",
    "email": "18763006837@163.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xcy960815/web-mask-layer.git/issues"
  },
  "homepage": "https://xcy960815.github.io/web-mask-layer/",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.4",
    "@vue/compiler-sfc": "^3.5.17",
    "@vitejs/plugin-vue": "^5.1.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.8.0",
    "husky": "^9.1.4",
    "less": "^4.1.3",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "rollup": "^4.44.1",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.0.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^5.4.10",
    "vitepress": "^1.3.4",
    "vue": "^3.5.17",
    "vue-tsc": "^2.1.8",
    "vue-eslint-parser": "^9.4.3"
  }
}
